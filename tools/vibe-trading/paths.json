{
    "name": "Vibe-Trading",
    "category": "AutoTrading",
    "apiProtocol": [
        "openai"
    ],
    "docs": "https://vibetrading.wiki/docs/",
    "installUrl": "https://github.com/HKUDS/Vibe-Trading",
    "command": "vibe-trading",
    "startCommand": "vibe-trading",
    "configDir": "~/.vibe-trading",
    "configFile": "~/.vibe-trading/.env",
    "requireConfigFile": false,
    "paths": {
        "win32": [
            "%USERPROFILE%\\.local\\bin\\vibe-trading.exe",
            "%APPDATA%\\Python\\Scripts\\vibe-trading.exe",
            "%LOCALAPPDATA%\\Programs\\Python\\Python313\\Scripts\\vibe-trading.exe",
            "%LOCALAPPDATA%\\Programs\\Python\\Python312\\Scripts\\vibe-trading.exe",
            "%LOCALAPPDATA%\\Programs\\Python\\Python311\\Scripts\\vibe-trading.exe"
        ],
        "darwin": [
            "/usr/local/bin/vibe-trading",
            "/opt/homebrew/bin/vibe-trading",
            "~/.local/bin/vibe-trading"
        ],
        "linux": [
            "/usr/local/bin/vibe-trading",
            "/usr/bin/vibe-trading",
            "~/.local/bin/vibe-trading"
        ]
    }
}
